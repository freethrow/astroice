---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { contentfulClient, optimizeImage } from '../lib/contentful';

// Fetch data with error handling
let events = [];
let articles = [];
let gallery = null;
let customPages = [];

try {
  console.log('Fetching events...');
  const eventRes = await contentfulClient.getEntries({
    content_type: 'event',
    limit: 3,
    order: '-sys.createdAt'
  });
  events = eventRes.items || [];
  console.log(`Fetched ${events.length} events`);
  
  console.log('Fetching articles...');
  const articleRes = await contentfulClient.getEntries({
    content_type: 'article',
    limit: 2,
    order: '-sys.createdAt'
  });
  articles = articleRes.items || [];
  console.log(`Fetched ${articles.length} articles`);
  
  console.log('Fetching gallery...');
  const galleryRes = await contentfulClient.getEntries({
    content_type: 'gallery',
    limit: 1,
    order: 'sys.createdAt'
  });
  gallery = galleryRes.items && galleryRes.items.length > 0 ? galleryRes.items[0] : null;

  const customPagesRes = await contentfulClient.getEntries({
    content_type: 'customPage',
    'fields.active': true,
  });
  customPages = customPagesRes.items || [];
} catch (error) {
  console.error('Error fetching content:', error);
}

function formatDate(dateString) {
  if (!dateString) return '';
  const date = new Date(dateString);
  return date.toLocaleDateString('sr-latn', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

function getRandomVideo() {
  //const videos = ['/MAC.mp4', '/Agri-food_SAFE.mp4'];
  //const randomIndex = Math.floor(Math.random() * videos.length);
  //return videos[randomIndex];
  return '/ITAsmall.mp4';
}

function isEventPast(eventTime) {
  const now = new Date();
  const eventDate = new Date(eventTime);
  return eventDate < now;
}

// Safely determine event title
let eventTitle = "Događaji"; // Default title
if (events[0] && events[0]?.fields?.eventTime) {
  eventTitle = isEventPast(events[0].fields.eventTime) ? 
    "Poslednji događaj" : 
    "Najava događaja";
}

const randomVideo = getRandomVideo();
---

<Layout title="ITA Belgrade">
  <div class="container max-w-5xl md:mx-auto px-4">
    <!-- Video Section -->
    <div class="aspect-video w-full my-8 bg-gray-100">
      <video 
        autoplay 
        muted 
        loop 
        playsinline
        class="w-full h-full object-cover"
        src={randomVideo}
      >
      </video>
    </div>

    <!-- Custom Pages Banner -->
    {customPages.length > 0 && customPages.map((page: any) => (
      <a
        href={`/${page.fields.url}`}
        class="group flex items-center justify-between gap-6 bg-white border border-itaGreen rounded-lg px-6 py-5 mb-8 hover:opacity-80 transition-opacity"
      >
        <div class="flex flex-col gap-1">
          <span class="font-archivo text-xs uppercase tracking-widest font-semibold text-itaGreen">
            Posebna stranica
          </span>
          <span class="font-archivo font-bold text-xl text-itaGreen">
            {page.fields.title}
          </span>
          {page.fields.subtitle && (
            <span class="font-roboto font-light text-sm text-itaGreen opacity-80">
              {page.fields.subtitle}
            </span>
          )}
        </div>
        <span class="font-archivo font-bold text-xs uppercase tracking-widest whitespace-nowrap px-5 py-3 rounded bg-itaGreen text-white flex-shrink-0">
          Pogledaj →
        </span>
      </a>
    ))}

    <!-- Main Grid Section -->
    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <!-- Events Column -->
      <div class="md:col-span-2">
        <h2 class="font-archivo text-itaGreen font-bold text-xl border-itaGreen my-2 border-b-2">
          {eventTitle}
        </h2>
        {events[0] && events[0]?.fields?.slug && events[0]?.fields?.title && events[0]?.fields?.cover?.fields?.file?.url && (
          <div class="bg-white shadow-lg rounded-lg overflow-hidden h-[500px]">
            <a href={`/events/${events[0].fields.slug}`} class="flex flex-col h-full">
              <div class="h-[300px] overflow-hidden">
                <Image 
                  src={optimizeImage(events[0].fields.cover, {width: 800, height: 400, fit: 'fill'})?.src || ''}
                  alt={events[0].fields.title}
                  width={800}
                  height={400}
                  loading="eager"
                  format="webp"
                  quality={85}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="p-6 flex-1 flex flex-col">
                <h3 class="font-archivo text-xl text-itaGreen mb-2 line-clamp-2">
                  {events[0].fields.title}
                </h3>
                <p class="text-itaGray mb-4 line-clamp-3 flex-1">
                  {events[0].fields.short || ''}
                </p>
                <time class="text-sm text-itaGray mt-auto">
                  {formatDate(events[0].fields.eventTime)}
                </time>
              </div>
            </a>
          </div>
        )}
      </div>

      <!-- News Column -->
      <div>
        <h2 class="font-archivo text-itaRed font-bold text-xl border-itaRed my-2 border-b-2">
          Novosti
        </h2>
        <div class="space-y-4">
          {articles.map(article => {
            // Check if article has all required fields
            const hasRequiredFields = article?.fields?.slug && 
                                      article?.fields?.title && 
                                      article?.fields?.cover?.fields?.file?.url;
            
            if (!hasRequiredFields) return null;
            
            return (
              <a 
                href={`/articles/${article.fields.slug}`}
                class="block bg-white shadow hover:shadow-md transition-shadow duration-300 rounded-lg overflow-hidden h-[240px]"
              >
                <div class="h-[140px] overflow-hidden">
                  <Image 
                    src={optimizeImage(article.fields.cover, {width: 400, height: 200, fit: 'fill'})?.src || ''}
                    alt={article.fields.title}
                    width={400}
                    height={200}
                    loading="lazy"
                    format="webp"
                    quality={80}
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                  />
                </div>
                <div class="p-4 h-[100px] flex flex-col">
                  <h3 class="font-archivo text-itaGray font-medium mb-2 line-clamp-2">
                    {article.fields.title}
                  </h3>
                  <time class="text-sm text-itaGray mt-auto">
                    {formatDate(article.fields.date)}
                  </time>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>

    <!-- Latest Events and Articles Grid -->
    <div class="grid md:grid-cols-2 gap-8 my-12">
      <!-- Latest Events -->
      <div>
        <h2 class="font-archivo text-itaGreen font-bold text-xl border-itaGreen mb-6 border-b-2">
          Najnoviji događaji
        </h2>
        <div class="space-y-6">
          {events.slice(1,3).map(event => {
            // Check if event has all required fields
            const hasRequiredFields = event?.fields?.slug && 
                                     event?.fields?.title && 
                                     event?.fields?.cover?.fields?.file?.url;
            
            if (!hasRequiredFields) return null;
            
            return (
              <a 
                href={`/events/${event.fields.slug}`}
                class="block bg-white shadow-md hover:shadow-lg transition-shadow duration-300 rounded-lg overflow-hidden h-[160px]"
              >
                <div class="flex h-full">
                  <div class="w-1/3 overflow-hidden">
                    <img 
                      src={`https:${event.fields.cover.fields.file.url}`}
                      alt={event.fields.title}
                      class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                    />
                  </div>
                  <div class="w-2/3 p-4 flex flex-col">
                    <h3 class="font-archivo text-itaGreen font-medium mb-2 line-clamp-2">
                      {event.fields.title}
                    </h3>
                    <p class="text-sm text-itaGray mb-2 line-clamp-2 flex-1">
                      {event.fields.short || ''}
                    </p>
                    <time class="text-sm text-itaGray mt-auto">
                      {formatDate(event.fields.eventTime)}
                    </time>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>

      <!-- Latest Articles -->
      <div>
        <h2 class="font-archivo text-itaRed font-bold text-xl border-itaRed mb-6 border-b-2">
          Najnoviji članci
        </h2>
        <div class="space-y-6">
          {articles.slice(0, 2).map(article => {
            // Check if article has all required fields
            const hasRequiredFields = article?.fields?.slug && 
                                     article?.fields?.title && 
                                     article?.fields?.cover?.fields?.file?.url;
            
            if (!hasRequiredFields) return null;
            
            return (
              <a 
                href={`/articles/${article.fields.slug}`}
                class="block bg-white shadow-md hover:shadow-lg transition-shadow duration-300 rounded-lg overflow-hidden h-[160px]"
              >
                <div class="flex h-full">
                  <div class="w-1/3 overflow-hidden">
                    <img 
                      src={`https:${article.fields.cover.fields.file.url}`}
                      alt={article.fields.title}
                      class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                    />
                  </div>
                  <div class="w-2/3 p-4 flex flex-col">
                    <h3 class="font-archivo text-itaGray font-medium mb-2 line-clamp-2">
                      {article.fields.title}
                    </h3>
                    <p class="text-sm text-itaGray mb-2 line-clamp-2 flex-1">
                      {article.fields.short || ''}
                    </p>
                    <time class="text-sm text-itaGray mt-auto">
                      {formatDate(article.fields.date)}
                    </time>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</Layout>